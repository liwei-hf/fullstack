# =============================================================================
# 生产环境变量示例（演示部署版）
# 适用场景：
# 1. 单机部署
# 2. 使用 Nginx 反向代理 admin / mobile / api
# 3. PostgreSQL、Redis、MinIO 与后端部署在同一台机器
# =============================================================================

# 服务器配置
PORT=3334
CORS_ORIGINS=https://admin.example.com,https://m.example.com

# 数据库配置（PostgreSQL + pgvector）
DATABASE_URL=postgresql://postgres:replace-with-strong-password@127.0.0.1:5432/fullstack

# JWT 配置
JWT_ACCESS_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_EXPIRES_IN=8h

# Refresh Token 配置
REFRESH_TOKEN_TTL_DAYS=7

# 默认密码
DEFAULT_USER_PASSWORD=ChangeMe123!

# 种子数据 - 管理员账号
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PHONE=13800000000
SEED_ADMIN_PASSWORD=Admin123456!

# AI 模型配置（按你的供应商实际填写）
OPENAI_API_KEY=replace-with-openai-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_SQL_MODEL=gpt-4o-mini
OPENAI_ANSWER_MODEL=gpt-4o-mini
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_API_KEY=
OPENAI_EMBEDDING_BASE_URL=
OPENAI_RERANK_MODEL=
OPENAI_RERANK_API_KEY=
OPENAI_RERANK_BASE_URL=

# 智谱配置（如果知识库问答走智谱推荐填写）
ZHIPU_API_KEY=replace-with-zhipu-key
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_CHAT_MODEL=glm-4.7-flashx
ZHIPU_EMBEDDING_MODEL=embedding-3
ZHIPU_RERANK_MODEL=rerank

# MinIO 配置
MINIO_ENDPOINT=127.0.0.1
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=replace-with-strong-minio-secret
MINIO_BUCKET=knowledge-base

# Redis 配置
REDIS_URL=redis://127.0.0.1:6379/0
