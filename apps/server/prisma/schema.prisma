// Prisma Schema - 数据库模型定义
//
// 数据库：PostgreSQL
// ORM：Prisma（类型安全的数据库访问层）
//
// 核心模型：
// - User：用户表，包含管理员和普通用户
// - Session：会话表，管理 JWT Refresh Token 和用户登录状态

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ====================== 枚举类型定义 ======================

// 用户角色
// - ADMIN：管理员，可访问管理后台
// - USER：普通用户，仅可访问移动端应用
enum UserRole {
  ADMIN
  USER
}

// 用户状态
// - ACTIVE：正常状态，可登录和使用系统
// - DISABLED：已禁用，无法登录（管理员可操作）
enum UserStatus {
  ACTIVE
  DISABLED
}

// 客户端类型（用于区分登录来源）
// - ADMIN：管理后台登录
// - MOBILE：移动端应用登录
enum ClientType {
  ADMIN
  MOBILE
}

// 会话状态
// - ACTIVE：活跃会话，Token 有效
// - REVOKED：已撤销会话，Token 失效（登出、重置密码、禁用用户时撤销）
enum SessionStatus {
  ACTIVE
  REVOKED
}

// Todo 任务状态枚举
enum TodoStatus {
  TODO
  IN_PROGRESS
  DONE
}

// 文档处理状态
enum DocumentStatus {
  UPLOADED
  PROCESSING
  READY
  FAILED
  DELETING
  DELETE_FAILED
}

// 文档切片策略
enum DocumentChunkStrategy {
  FIXED
  PARAGRAPH
  HEADING
}

// ZIP 批量导入任务状态
enum KnowledgeBaseImportJobStatus {
  UPLOADED
  PROCESSING
  COMPLETED
  FAILED
  PARTIAL_SUCCESS
}

// Prompt 版本状态
enum PromptVersionStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

// 部门枚举（用于用户所属部门）
enum DepartmentName {
  ENGINEERING  // 研发部
  HR          // 人事部
  SALES       // 销售部
}

model Department {
  id          String   @id @default(cuid())
  name        String   @unique               // 部门名称
  description String?                        // 部门描述
  users       User[]                         // 关联用户
}

// ====================== 数据模型 ======================

// 用户模型
// 存储用户基本信息、认证凭据和状态
model User {
  id            String       @id @default(cuid())  // 用户 ID（cuid 格式）
  username      String       @unique               // 用户名（唯一）
  phone         String       @unique               // 手机号（唯一）
  passwordHash  String                             // bcrypt 加密后的密码哈希
  role          UserRole     @default(USER)        // 用户角色（默认普通用户）
  status        UserStatus   @default(ACTIVE)      // 用户状态（默认激活）
  lastLoginAt   DateTime?                          // 最后登录时间（可选）
  createdAt     DateTime     @default(now())       // 创建时间
  updatedAt     DateTime     @updatedAt            // 更新时间（自动更新）
  departmentId  String?                            // 所属部门 ID（可选）
  sessions      Session[]                          // 关联的会话（一对多）
  todos         Todo[]                             // 关联的任务（一对多）
  createdKnowledgeBases KnowledgeBase[] @relation("KnowledgeBaseCreator")
  uploadedDocuments Document[]        @relation("DocumentUploader")
  qaLogs        QaLog[]
  aiSqlLogs     AiSqlLog[]
  promptVersions PromptVersion[] @relation("PromptVersionCreator")
  promptTestLogs PromptTestLog[]
  importJobs    KnowledgeBaseImportJob[] @relation("KnowledgeBaseImportUploader")
  department    Department?  @relation(fields: [departmentId], references: [id]) // 关联部门

  // 索引优化查询性能
  @@index([username])
  @@index([phone])
  @@index([role])
  @@index([status])
  @@index([departmentId])
}

// 会话模型
// 管理用户登录状态和 Refresh Token
// 支持单会话（移动端）和多会话（管理端）策略
model Session {
  id             String        @id @default(cuid())        // 会话 ID
  userId         String                                    // 用户 ID（外键）
  clientType     ClientType                                // 客户端类型（ADMIN/MOBILE）
  deviceId       String?                                   // 设备 ID（可选，用于移动端标识）
  refreshTokenHash String                                  // Refresh Token 的 SHA256 哈希（不存储明文）
  status         SessionStatus @default(ACTIVE)            // 会话状态（默认活跃）
  lastActiveAt   DateTime      @default(now())             // 最后活跃时间
  revokedAt      DateTime?                                 // 撤销时间（可选）
  expiresAt      DateTime                                  // 过期时间（默认 7 天）
  createdAt      DateTime      @default(now())             // 创建时间
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)  // 关联用户（级联删除）

  // 索引优化查询性能
  @@index([userId])
  @@index([refreshTokenHash])
  @@index([status])
  @@index([expiresAt])
}

// ====================== Todo 任务模型 ======================

// Todo 任务模型
// 用于管理用户的个人任务列表，支持待办、进行中、已完成三种状态
model Todo {
  id          String      @id @default(cuid())      // 任务 ID（cuid 格式）
  userId      String                                // 所属用户 ID（外键）
  title       String                                // 任务标题（必填）
  description String?                               // 任务描述（可选）
  status      TodoStatus    @default(TODO)          // 任务状态（默认待办）
  createdAt   DateTime      @default(now())         // 创建时间
  updatedAt   DateTime      @updatedAt              // 更新时间（自动更新）

  // 关联用户（一个用户可以有多个任务，删除用户时级联删除任务）
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 索引优化查询性能
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// ====================== 知识库与 RAG 相关模型 ======================

model KnowledgeBase {
  id            String     @id @default(cuid())
  name          String     @unique
  description   String?
  createdById   String
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  createdBy     User       @relation("KnowledgeBaseCreator", fields: [createdById], references: [id], onDelete: Restrict)
  documents     Document[]
  qaLogs        QaLog[]
  importJobs    KnowledgeBaseImportJob[]

  @@index([createdById])
  @@index([createdAt])
}

model Document {
  id              String         @id @default(cuid())
  knowledgeBaseId String
  uploadedById    String
  importJobId     String?
  fileName        String
  fileType        String
  chunkStrategy   DocumentChunkStrategy @default(FIXED)
  objectKey       String         @unique
  status          DocumentStatus @default(UPLOADED)
  chunkCount      Int            @default(0)
  characterCount  Int            @default(0)
  failureReason   String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  knowledgeBase   KnowledgeBase  @relation(fields: [knowledgeBaseId], references: [id], onDelete: Restrict)
  uploadedBy      User           @relation("DocumentUploader", fields: [uploadedById], references: [id], onDelete: Restrict)
  importJob       KnowledgeBaseImportJob? @relation(fields: [importJobId], references: [id], onDelete: SetNull)
  chunks          DocumentChunk[]

  @@index([knowledgeBaseId])
  @@index([uploadedById])
  @@index([importJobId])
  @@index([status])
  @@index([createdAt])
}

model KnowledgeBaseImportJob {
  id               String                     @id @default(cuid())
  knowledgeBaseId  String
  uploadedById     String
  fileName         String
  objectKey        String                     @unique
  chunkStrategy    DocumentChunkStrategy      @default(FIXED)
  status           KnowledgeBaseImportJobStatus @default(UPLOADED)
  totalFileCount   Int                        @default(0)
  successFileCount Int                        @default(0)
  failedFileCount  Int                        @default(0)
  failureReason    String?
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
  knowledgeBase    KnowledgeBase              @relation(fields: [knowledgeBaseId], references: [id], onDelete: Restrict)
  uploadedBy       User                       @relation("KnowledgeBaseImportUploader", fields: [uploadedById], references: [id], onDelete: Restrict)
  documents        Document[]

  @@index([knowledgeBaseId])
  @@index([uploadedById])
  @@index([status])
  @@index([createdAt])
}

model DocumentChunk {
  id         String   @id @default(cuid())
  documentId String
  sequence   Int
  content    String
  excerpt    String
  embedding  Unsupported("vector")?
  metadata   Json?
  createdAt  DateTime @default(now())
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([documentId, sequence])
}

model QaLog {
  id              String        @id @default(cuid())
  knowledgeBaseId String
  userId          String
  requestId       String?
  question        String
  answer          String?
  sourceCount     Int           @default(0)
  durationMs      Int?
  success         Boolean       @default(true)
  errorMessage    String?
  createdAt       DateTime      @default(now())
  knowledgeBase   KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Restrict)
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([knowledgeBaseId])
  @@index([userId])
  @@index([requestId])
  @@index([createdAt])
}

model AiSqlLog {
  id           String   @id @default(cuid())
  userId       String
  requestId    String?
  question     String
  answer       String?
  sql          String?
  rowCount     Int      @default(0)
  durationMs   Int?
  success      Boolean  @default(true)
  errorMessage String?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([requestId])
  @@index([createdAt])
}

model PromptTemplate {
  id          String          @id @default(cuid())
  code        String          @unique
  name        String
  description String?
  scene       String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  versions    PromptVersion[]

  @@index([scene])
  @@index([createdAt])
}

model PromptVersion {
  id                 String              @id @default(cuid())
  templateId         String
  version            Int
  systemPrompt       String
  userPromptTemplate String
  variablesSchema    Json?
  status             PromptVersionStatus @default(DRAFT)
  createdById        String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  template           PromptTemplate      @relation(fields: [templateId], references: [id], onDelete: Cascade)
  createdBy          User                @relation("PromptVersionCreator", fields: [createdById], references: [id], onDelete: Restrict)
  testLogs           PromptTestLog[]

  @@unique([templateId, version])
  @@index([templateId, status])
  @@index([createdById])
  @@index([createdAt])
}

model PromptTestLog {
  id              String         @id @default(cuid())
  templateCode    String
  promptVersionId String?
  input           Json
  resolvedPrompt  Json
  output          String?
  durationMs      Int?
  success         Boolean        @default(false)
  errorMessage    String?
  createdById     String
  createdAt       DateTime       @default(now())
  promptVersion   PromptVersion? @relation(fields: [promptVersionId], references: [id], onDelete: SetNull)
  createdBy       User           @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@index([templateCode])
  @@index([promptVersionId])
  @@index([createdById])
  @@index([createdAt])
}
