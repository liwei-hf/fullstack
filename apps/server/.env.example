# 服务器配置
PORT=3334

# CORS 白名单（生产环境建议填写域名，用英文逗号分隔）
# 例如：https://admin.example.com,https://m.example.com
CORS_ORIGINS=

# 数据库配置
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fullstack

# JWT 配置
JWT_ACCESS_SECRET=replace-with-access-secret
JWT_ACCESS_EXPIRES_IN=8h

# Refresh Token 配置
REFRESH_TOKEN_TTL_DAYS=7

# 默认密码
DEFAULT_USER_PASSWORD=ChangeMe123!

# 种子数据 - 管理员账号
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PHONE=13800000000
SEED_ADMIN_PASSWORD=Admin123456!

# AI 模型配置
OPENAI_API_KEY=replace-with-openai-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_SQL_MODEL=gpt-4o-mini
OPENAI_ANSWER_MODEL=gpt-4o-mini
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# 智能问数 SQL 对前端的可见性：
# - visible：所有用户可见
# - hidden：所有用户不可见
# - admin_only：仅管理员可见（默认）
AI_SQL_VISIBILITY=admin_only
OPENAI_EMBEDDING_API_KEY=
OPENAI_EMBEDDING_BASE_URL=
OPENAI_RERANK_MODEL=
OPENAI_RERANK_API_KEY=
OPENAI_RERANK_BASE_URL=

# 智谱配置（RAG 推荐）
ZHIPU_API_KEY=replace-with-zhipu-key
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_CHAT_MODEL=glm-4.7-flashx
ZHIPU_EMBEDDING_MODEL=embedding-3
ZHIPU_RERANK_MODEL=rerank

# MinIO 配置
MINIO_ENDPOINT=127.0.0.1
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=knowledge-base

# Redis 配置（BullMQ 队列 / 热点缓存 / 多轮对话短期记忆）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=
