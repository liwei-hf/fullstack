# 服务器配置
PORT=3000

# 数据库配置
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fullstack_interview?schema=public"

# JWT 配置
JWT_ACCESS_SECRET="your-super-secret-key-change-in-production"
JWT_ACCESS_EXPIRES_IN="15m"

# Refresh Token 配置
REFRESH_TOKEN_TTL_DAYS=7

# 默认密码
