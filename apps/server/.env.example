# ===================================
# 后端环境变量配置示例
# ===================================

# 数据库配置
# 格式：postgresql://用户：密码@主机：端口/数据库名
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fullstack_interview?schema=public"

# 服务端口
PORT=3000

# JWT 配置
# 生产环境请修改为随机字符串
JWT_ACCESS_SECRET="replace-with-access-secret"
JWT_ACCESS_EXPIRES_IN="15m"

# Refresh Token 有效期（天）
REFRESH_TOKEN_TTL_DAYS=7

# 默认用户密码（新用户初始密码）
DEFAULT_USER_PASSWORD="ChangeMe123!"

# 种子数据配置（管理员账号）
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_PHONE="13800000000"
SEED_ADMIN_NICKNAME="系统管理员"
SEED_ADMIN_PASSWORD="Admin123456!"
