{
  "name": "fullstack-ai-platform",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "turbo run dev",
    "dev:server": "turbo run dev --filter=@fullstack/server",
    "dev:admin": "turbo run dev --filter=@fullstack/admin",
    "dev:mobile": "turbo run dev --filter=@fullstack/mobile",
    "build": "turbo run build",
    "build:server": "turbo run build --filter=@fullstack/server",
    "build:admin": "turbo run build --filter=@fullstack/admin",
    "start:server": "pnpm --filter=@fullstack/server start",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter=@fullstack/server prisma generate",
    "db:push": "pnpm --filter=@fullstack/server prisma db push",
    "db:seed": "pnpm --filter=@fullstack/server prisma db seed",
    "db:migrate": "pnpm --filter=@fullstack/server prisma migrate dev",
    "deploy:sync": "bash deploy/scripts/sync-demo-server.sh",
    "deploy:nginx": "bash deploy/scripts/sync-demo-nginx.sh",
    "deploy:release:build": "bash deploy/scripts/build-demo-release.sh",
    "deploy:release": "bash deploy/scripts/deploy-demo-release.sh"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  }
}
