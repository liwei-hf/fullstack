{
  "name": "fullstack-interview-project",
  "private": true,
  "packageManager": "pnpm@10.6.5",
  "scripts": {
    "dev": "turbo dev",
    "dev:all": "turbo dev",
    "dev:server": "turbo dev --filter=@fullstack/server",
    "dev:admin": "turbo dev --filter=@fullstack/admin",
    "dev:mobile": "turbo dev --filter=@fullstack/mobile",
    "build": "turbo build",
    "build:server": "turbo build --filter=@fullstack/server",
    "build:admin": "turbo build --filter=@fullstack/admin",
    "build:mobile": "turbo build --filter=@fullstack/mobile",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:generate": "pnpm --filter @fullstack/server prisma generate",
    "db:migrate": "pnpm --filter @fullstack/server prisma migrate dev",
    "db:seed": "pnpm --filter @fullstack/server prisma db seed",
    "db:reset": "pnpm --filter @fullstack/server prisma migrate reset"
  },
  "devDependencies": {
    "turbo": "^2.8.21",
    "typescript": "^6.0.2"
  }
}
